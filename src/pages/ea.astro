document.addEventListener('DOMContentLoaded', () => {
  const prefer = (navigator.language || '').startsWith('ja');
  LANG.set(prefer ? 'JP' : 'EN');
  document.querySelectorAll('.lang-btn').forEach(b => {
    b.addEventListener('click', () => LANG.set(b.dataset.lang));
  });
  // Scroll animation
  new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 }).observe(document.querySelector('.hero'));
  document.querySelectorAll('.fade-in').forEach(el => {
    new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 }).observe(el);
  });
  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      const t = document.querySelector(a.getAttribute('href'));
      if (t) t.scrollIntoView({ behavior: 'smooth' });
    });
  });
  // Form -> mailto
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const n = document.getElementById('name').value;
      const em = document.getElementById('email').value;
      const tp = document.getElementById('type').value;
      const msg = document.getElementById('message').value;
      const sj = LANG.current === 'JP'
        ? `【FusionGold M5】${tp === 'barter' ? '物々交換' : 'お問い合わせ'}（${n}様）`
        : `[FusionGold M5] Inquiry from ${n}`;
      const bd = LANG.current === 'JP'
        ? `お名前: ${n}\nメール: ${em}\n種別: ${tp}\n\n${msg}\n\n-- ${em}`
        : `Name: ${n}\nEmail: ${em}\nType: ${tp}\n\n${msg}\n\n-- ${em}`;
      window.location.href = `mailto:william1412@agent.qq.com?subject=${encodeURIComponent(sj)}&body=${encodeURIComponent(bd)}`;
      const btn = form.querySelector('.form-submit');
      btn.textContent = LANG.current === 'JP' ? '✓ メール作成中...' : '✓ Opening email...';
      btn.disabled = true;
      setTimeout(() => { btn.textContent = LANG.current === 'JP' ? '送信する' : 'Send'; btn.disabled = false; }, 5000);
    });
