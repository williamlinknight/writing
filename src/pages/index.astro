---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 6);
---

<MainLayout 
  title="厦门灯塔 | 英文作文批改 · 雅思写作 · 逐句精批 | 威廉老师"
  description="专业英文作文逐句批改服务，覆盖中高考、雅思写作。威廉老师人工深度批改，逐句分析+逻辑重构+母语级表达升级。累计批改300+篇。"
  image="https://www.williamwriting.com/og-default.png"
  canonicalUrl="https://www.williamwriting.com/"
>
  <Navbar />

<meta name="keywords" content="英文作文批改,厦门英语写作,中高考英语,雅思写作,英语作文提分,逐句批改,威廉老师,厦门灯塔" />

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://www.williamwriting.com/#organization",
          "name": "厦门灯塔",
          "url": "https://www.williamwriting.com",
          "description": "英文作文逐句批改服务，专业人工深度批改",
          "foundingDate": "2023",
          "areaServed": "CN",
          "address": { "@type": "PostalAddress", "addressLocality": "厦门", "addressRegion": "福建", "addressCountry": "CN" },
          "contactPoint": { "@type": "ContactPoint", "contactType": "customer service", "telephone": "+86-linstudio799", "email": "linstudio799@wechat.com" },
          "founder": { "@type": "Person", "@id": "https://www.williamwriting.com/#founder", "name": "William", "description": "厦门灯塔创始人，英文作文教学专家" }
        },
        {
          "@type": "Person", "@id": "https://www.williamwriting.com/#person",
          "name": "William", "description": "英文作文教学专家，厦门灯塔创始人",
          "url": "https://www.williamwriting.com/about",
          "knowsAbout": ["英语教学", "英文写作", "雅思写作", "高考英语", "中考英语"]
        }
      ]
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "为什么校内作文反馈难以满足需求？",
          "acceptedAnswer": { "@type": "Answer", "text": "1. 时间有限：一位老师面对50+学生，每篇批改不足3分钟。2. 标准模糊：批注如「结构不清」但孩子不知如何改进。3. 缺乏跟踪：没有后续订正和巩固练习。4. 应试脱节：日常练习与考试评分标准存在差距。" }
        },
        {
          "@type": "Question",
          "name": "校内作文批改和一对一专业批改有什么区别？",
          "acceptedAnswer": { "@type": "Answer", "text": "校内批改通常只有分数和简短批注（如「需改进」），而林老师的批改会逐句标注每一处语法错误，提供3种以上修改方案，按中考/高考标准打分，并附词汇升级清单和结构建议。" }
        },
        {
          "@type": "Question",
          "name": "林老师作文批改服务有哪些优势？",
          "acceptedAnswer": { "@type": "Answer", "text": "五大优势：1. 专业细致的PDF批改报告（红笔标注、多方案修改、中考/高考标准打分）。2. 24小时快速反馈。3. 闭环学习系统（批改→订正→练习→复查）。4. 考试导向训练（真题库、热点预测、高分模板）。5. 透明定价¥99/篇。" }
        },
        {
          "@type": "Question",
          "name": "怎么联系林老师开始批改？",
          "acceptedAnswer": { "@type": "Answer", "text": "添加微信 LinStudio799（备注\u201c作文批改+年级\u201d），拍照发送作文，即可在24小时内收到专业批改报告。" }
        }
      ]
    }
  </script>

  <!-- ============ HERO ============ -->
  <header style="padding: 100px 24px 80px; text-align: center; background: linear-gradient(135deg, var(--brand-light) 0%, #fce4d6 100%);">
    <div class="container" style="max-width: 720px; margin: 0 auto;">
      <p style="font-size: 0.9rem; color: var(--brand); font-weight: 600; margin-bottom: 20px;">厦门 · 专业英语作文批改</p>
      <h1 style="font-size: 3rem; color: var(--text-heading); margin-bottom: 8px; font-family: var(--font-heading);">厦门灯塔</h1>
      <p style="font-size: 1.4rem; color: var(--brand-dark); font-weight: 500; margin-bottom: 6px;">英文作文逐句批改服务</p>
      <p style="font-size: 2rem; color: var(--brand); font-weight: 800; margin-bottom: 12px;">¥99 <span style="font-size: 1rem; font-weight: 400;">/ 篇</span></p>
      <p style="font-size: 1.05rem; max-width: 560px; margin: 0 auto; color: var(--text-muted);">专业人工深度批改 · 逐句分析 + 逻辑重构 + 母语级表达升级</p>
      <div style="margin-top: 28px;">
        <a href="#cta" style="display: inline-block; padding: 14px 44px; background: var(--brand); color: white; border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 1rem;">立即咨询 →</a>
        <a href="/blog/" style="display: inline-block; margin-left: 12px; padding: 14px 32px; background: white; color: var(--text-heading); border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 1rem; border: 1px solid var(--border-light);">阅读文章</a>
      </div>
    </div>
  </header>

  <main style="max-width: 720px; margin: 0 auto; padding: 50px 24px 60px;">

    <!-- ============ PROBLEM ============ -->
    <section style="margin-bottom: 50px;">
      <p style="font-size: 1.1rem; line-height: 2; color: var(--text-body);">
        <strong>"林老师，我家孩子英语考试其他部分都不错，就是作文总是拿不到高分，怎么办？"</strong>
      </p>
      <p style="font-size: 1rem; line-height: 1.9; color: var(--text-muted); margin-top: 16px;">
        当我问「学校老师有没有告诉孩子作文具体哪里需要改进？」大多数家长都无奈地摇头：<strong style="color: var(--text-body);">只有分数，却不知道问题出在哪里。</strong>
      </p>
      <div style="margin-top: 24px; padding: 16px 20px; background: var(--brand-light); border-radius: 8px; border-left: 4px solid var(--brand);">
        <p style="font-size: 0.95rem; color: var(--text-body); line-height: 1.7;">
          <strong>📊 厦门灯塔批改数据：</strong>根据300+篇中学生作文的统计，超过80%的扣分集中在语法错误、中式表达和结构混乱上。然而超过90%的学校批改仅给出分数，没有具体改进方案——这正是专业批改的核心价值所在。
        </p>
      </div>
    </section>

    <hr style="border: none; border-top: 1px solid #eee; margin: 0 0 50px;">

    <!-- ============ CASE COMPARISON ============ -->
    <section style="margin-bottom: 50px;">
      <h2 style="font-size: 1.6rem; color: var(--text-heading); margin-bottom: 6px; font-family: var(--font-heading);">一个真实的对比案例</h2>
      <p style="color: var(--text-muted); margin-bottom: 30px;">上周批改的一位初二学生的作文</p>

      <div style="margin-bottom: 20px;">
        <h3 style="font-size: 1.1rem; color: #c53030; margin-bottom: 10px;">🏫 学校老师的批改</h3>
        <p style="font-size: 1rem; font-style: italic; color: var(--text-muted); background: #fff5f5; padding: 16px 20px; border-radius: 8px;">"I very like play basketball. It make me happy."</p>
        <p style="margin-top: 8px;"><strong style="font-size: 1.3rem; color: #c53030;">12 / 20</strong> <span style="color: var(--text-muted); font-size: 0.9rem; margin-left: 12px;">批注：需改进</span></p>
      </div>

      <div>
        <h3 style="font-size: 1.1rem; color: #276749; margin-bottom: 10px;">📝 林老师的批改</h3>
        <ul style="list-style: none; padding: 0; margin: 0; background: #f0fff4; padding: 16px 20px; border-radius: 8px;">
          <li style="padding: 6px 0; font-size: 0.95rem; color: var(--text-body); border-bottom: 1px solid #e2e8f0;">✓ "very like"→"really like"；"play"→"playing"</li>
          <li style="padding: 6px 0; font-size: 0.95rem; color: var(--text-body); border-bottom: 1px solid #e2e8f0;">✓ "make"→"makes"（主谓一致）</li>
          <li style="padding: 6px 0; font-size: 0.95rem; color: var(--text-body); border-bottom: 1px solid #e2e8f0;">✓ 升级表达："It brings me great joy..."</li>
          <li style="padding: 6px 0; font-size: 0.95rem; color: var(--text-body);">✓ 结构建议：补充具体事例</li>
        </ul>
      </div>

      <p style="margin-top: 24px; padding: 14px 20px; background: var(--brand-light); border-radius: 8px; color: var(--text-heading); font-weight: 500;">单纯的分数和"需改进"三个字，真的能帮助孩子进步吗？</p>
    </section>

    <hr style="border: none; border-top: 1px solid #eee; margin: 0 0 50px;">

    <!-- ============ PAIN POINTS ============ -->
    <section style="margin-bottom: 50px;">
      <h2 style="font-size: 1.6rem; color: var(--text-heading); margin-bottom: 24px; font-family: var(--font-heading);">为什么校内作文反馈难以满足需求？</h2>

      <div style="margin-bottom: 18px;">
        <p style="font-size: 1.05rem; font-weight: 600; color: var(--text-heading);">⏰ 时间有限</p>
        <p style="font-size: 0.95rem; color: var(--text-muted); margin-top: 4px;">一位老师面对50+学生，每篇作文批改时间不足3分钟</p>
      </div>
      <div style="margin-bottom: 18px;">
        <p style="font-size: 1.05rem; font-weight: 600; color: var(--text-heading);">❓ 标准模糊</p>
        <p style="font-size: 0.95rem; color: var(--text-muted); margin-top: 4px;">批注如"结构不清""用词简单"，但孩子不知道如何改进</p>
      </div>
      <div style="margin-bottom: 18px;">
        <p style="font-size: 1.05rem; font-weight: 600; color: var(--text-heading);">🔁 缺乏跟踪</p>
        <p style="font-size: 0.95rem; color: var(--text-muted); margin-top: 4px;">没有后续的订正和巩固练习，错误一犯再犯</p>
      </div>
      <div style="margin-bottom: 24px;">
        <p style="font-size: 1.05rem; font-weight: 600; color: var(--text-heading);">📊 应试脱节</p>
        <p style="font-size: 0.95rem; color: var(--text-muted); margin-top: 4px;">日常练习与考试评分标准存在差距</p>
      </div>

      <div style="padding: 16px 20px; background: white; border-radius: 8px; border-left: 4px solid var(--brand);">
        <p style="font-style: italic; color: var(--text-muted);">"孩子月考英语作文16分，我问他老师说了什么需要改进，他居然说老师只说了'还可以'..."</p>
        <p style="text-align: right; color: var(--text-muted); font-size: 0.85rem; margin-top: 6px;">——张妈妈，初三家长</p>
      </div>
    </section>

    <hr style="border: none; border-top: 1px solid #eee; margin: 0 0 50px;">

    <!-- ============ ADVANTAGES ============ -->
    <section style="margin-bottom: 50px;">
      <h2 style="font-size: 1.6rem; color: var(--text-heading); margin-bottom: 24px; font-family: var(--font-heading);">五大优势</h2>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 6px;"><span style="color: var(--brand); font-weight: 700;">1.</span> 专业细致的批改报告（PDF）</h3>
        <ul style="list-style: none; padding: 0; margin: 0 0 8px;">
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 红笔标注每一处错误</li>
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 提供3种以上修改方案</li>
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 按中考/高考标准打分</li>
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 附词汇升级清单</li>
        </ul>
        <p style="font-size: 0.9rem; color: var(--text-muted); background: var(--brand-light); padding: 10px 14px; border-radius: 6px;"><strong>示例：</strong>"The weather is good." → "The sun is shining brightly with a gentle breeze."</p>
      </div>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 6px;"><span style="color: var(--brand); font-weight: 700;">2.</span> 24小时快速反馈</h3>
        <p style="font-size: 0.95rem; color: var(--text-muted);">拍照发送作文后，24小时内收到完整批改报告。紧急需求可加急处理，当天完成。</p>
      </div>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 6px;"><span style="color: var(--brand); font-weight: 700;">3.</span> 闭环学习系统</h3>
        <p style="font-size: 0.95rem; color: var(--text-muted);">批改 → 订正 → 练习 → 复查，确保每个错误不重复犯。</p>
      </div>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 6px;"><span style="color: var(--brand); font-weight: 700;">4.</span> 考试导向训练</h3>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 近三年中考/高考真题库</li>
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 预测热点话题</li>
          <li style="font-size: 0.95rem; color: var(--text-muted); padding: 3px 0;">✓ 高分句型模板</li>
        </ul>
      </div>

      <div style="margin-bottom: 0;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 6px;"><span style="color: var(--brand); font-weight: 700;">5.</span> 透明定价：<span style="color: var(--brand);">¥99 / 篇</span></h3>
        <p style="font-size: 0.95rem; color: var(--text-muted);">单篇深度批改，含逐句批注+评分+优化版全文+练习题。微信投稿，24小时内返回。</p>
      </div>
    </section>

    <hr style="border: none; border-top: 1px solid #eee; margin: 0 0 50px;">

    <!-- ============ SERVICE FLOW ============ -->
    <section style="margin-bottom: 50px;">
      <h2 style="font-size: 1.6rem; color: var(--text-heading); margin-bottom: 24px; font-family: var(--font-heading);">服务流程</h2>
      <div style="margin-bottom: 16px;">
        <p style="font-size: 1rem;"><strong style="color: var(--brand);">1.</strong> 添加微信 <strong style="color: var(--brand);">LinStudio799</strong>（备注"作文批改+年级"）</p>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 2px;">¥99 / 篇</p>
      </div>
      <div style="margin-bottom: 16px;">
        <p style="font-size: 1rem;"><strong style="color: var(--brand);">2.</strong> 拍照发送作文（确保字迹清晰，注明题目要求）</p>
      </div>
      <div style="margin-bottom: 16px;">
        <p style="font-size: 1rem;"><strong style="color: var(--brand);">3.</strong> 接收批改报告（批注版+示范作文版+练习页）</p>
      </div>
      <div>
        <p style="font-size: 1rem;"><strong style="color: var(--brand);">4.</strong> 完成订正作业（抄正作文+完成练习，拍照发给老师检查）</p>
      </div>
    </section>

    <hr style="border: none; border-top: 1px solid #eee; margin: 0 0 50px;">

    <!-- ============ 致学生 ============ -->
    <section style="margin-bottom: 50px;">
      <h2 style="font-size: 1.6rem; color: var(--text-heading); margin-bottom: 6px; font-family: var(--font-heading);">致学生</h2>
      <p style="font-size: 1rem; color: var(--brand); font-weight: 600; margin-bottom: 24px;">收到了厦门灯塔老师的详细批改后，应该这样做</p>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 8px;"><span style="background: var(--brand); color: white; display: inline-block; width: 26px; height: 26px; border-radius: 50%; text-align: center; line-height: 26px; font-size: 0.85rem; margin-right: 6px;">1</span> 深度消化批改内容</h3>
        <p style="font-size: 0.95rem; color: var(--text-muted); margin-bottom: 6px;">收到批改作文后，请先逐行阅读威廉老师的批注：</p>
        <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.92rem; color: var(--text-muted);">
          <li style="padding: 4px 0;">• 批改标记的<strong style="color: var(--brand);">语法错误</strong>（如时态、冠词）需重点记忆</li>
          <li style="padding: 4px 0;">• 批注提出的<strong style="color: var(--brand);">优化建议</strong>（如逻辑衔接、词汇升级）要反复揣摩</li>
          <li style="padding: 4px 0;">• 批注为闪光点，可整理进你的<strong style="color: var(--brand);">「优秀表达库」</strong></li>
        </ul>
      </div>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 8px;"><span style="background: var(--brand); color: white; display: inline-block; width: 26px; height: 26px; border-radius: 50%; text-align: center; line-height: 26px; font-size: 0.85rem; margin-right: 6px;">2</span> 建立个人写作进化档案</h3>
        <p style="font-size: 0.95rem; color: var(--text-muted); margin-bottom: 6px;">准备专属的「作文精修笔记本」，完成：</p>
        <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.92rem; color: var(--text-muted);">
          <li style="padding: 4px 0;">• 工整誊抄最终修改版（含所有批注）</li>
          <li style="padding: 4px 0;">• 每篇末尾用红笔总结<strong style="color: var(--brand);">3个核心进步</strong></li>
          <li style="padding: 4px 0;">• 为同类错误贴标签索引：<strong style="color: var(--brand);">「时态专区」「逻辑衔接区」</strong></li>
        </ul>
      </div>

      <div style="margin-bottom: 24px;">
        <h3 style="font-size: 1.05rem; color: var(--text-heading); margin-bottom: 8px;"><span style="background: var(--brand); color: white; display: inline-block; width: 26px; height: 26px; border-radius: 50%; text-align: center; line-height: 26px; font-size: 0.85rem; margin-right: 6px;">3</span> 科学循环复习法</h3>
        <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.92rem; color: var(--text-muted);">
          <li style="padding: 4px 0;">• 第3天：快速重读批改笔记，用蓝笔标出仍存疑处</li>
          <li style="padding: 4px 0;">• 第7天：闭卷重写同题作文，对比原版与新版差异</li>
          <li style="padding: 4px 0;">• 第30天：将经典句式改编迁移到新作文（如环保模板→科技类）</li>
        </ul>
      </div>

      <div style="margin-bottom: 16px; padding: 16px 20px; border-left: 4px solid var(--brand); background: var(--brand-light); border-radius: 0 8px 8px 0;">
        <p style="font-size: 0.95rem; color: var(--text-body);"><strong>🏅 黄金原则：</strong>威廉老师特别强调，每周精选1-2篇作文进行深度批改，远胜于每天敷衍式练习。每次修改后，确保彻底消灭一类高频错误、掌握1个学术写作套路（如PEEL）、积累3个可复用高端表达。</p>
