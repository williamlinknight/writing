---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const ftPosts = allPosts
  .filter((post) => {
    const slug = post.id.toLowerCase();
    const title = post.data.title || '';
    return (
      slug.startsWith('ft-') ||
      title.includes('读《金融时报》') ||
      title.includes('读金融时报') ||
      title.includes('读外刊学写作')
    );
  })
  .sort((a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<MainLayout
  title="读《金融时报》学英文写作 - 厦门灯塔"
  description="从金融时报双语阅读中提炼英语写作技巧 | 词汇升级 · 句型模仿 · 论证方法 · 逻辑衔接"
>
  <Navbar />

  <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); padding: 80px 0 60px;">
    <div class="container" style="max-width: 720px; margin: 0 auto; padding: 0 24px; text-align: center;">
      <div style="font-size: 3rem; margin-bottom: 16px;">📰</div>
      <h1 style="font-family: var(--font-heading); font-size: 2.2rem; color: #fff; margin: 0 0 12px; line-height: 1.3;">
        读《金融时报》<br style="display: none;">学英文写作
      </h1>
      <p style="font-size: 1.05rem; color: rgba(255,255,255,0.7); margin: 0 auto 24px; max-width: 520px; line-height: 1.6;">
        每天一篇金融时报双语阅读，提炼一个可用的写作技巧——不靠死记硬背，从真实英文中学会写。
      </p>
      <div style="display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.1); padding: 8px 20px; border-radius: 50px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        共 <strong style="color: #fff; margin: 0 2px;">{ftPosts.length}</strong> 篇
      </div>
    </div>
  </div>

  <div style="padding: 60px 0 100px; background: #f5f0eb;">
    <div class="container" style="max-width: 720px; margin: 0 auto; padding: 0 24px;">

      <!-- Search -->
      <div id="search-wrapper" style="max-width: 680px; margin: 0 auto 36px; position: relative;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); pointer-events: none;">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="ft-search"
          type="text"
          placeholder="搜索文章标题..."
          style="width: 100%; padding: 14px 16px 14px 48px; border: 2px solid #e0d6cc; border-radius: 12px; font-size: 1rem; font-family: var(--font-body); background: #fff; color: var(--text-body); outline: none; transition: border-color 0.25s, box-shadow 0.25s;"
          onfocus="this.style.borderColor='var(--brand)'; this.style.boxShadow='0 0 0 3px rgba(230,126,96,0.15)'"
          onblur="this.style.borderColor='#e0d6cc'; this.style.boxShadow='none'"
        />
      </div>

      <!-- Post count -->
      <p id="ft-count" style="text-align: center; font-size: 0.9rem; color: var(--text-muted); margin: -20px 0 28px;">
        共 <span id="ft-count-num">{ftPosts.length}</span> 篇文章
      </p>

      <!-- Posts -->
      <div id="ft-posts" style="display: grid; gap: 24px;">
        {ftPosts.map((post) => {
          const slug = post.id.replace(/\.(md|mdx)$/, '');
          const pubDate = new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          const isFT = slug.startsWith('ft-');
          return (
            <article class="ft-card" data-title={post.data.title} style="background: #fff; border-radius: 12px; padding: 28px 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: box-shadow 0.25s, transform 0.25s;"
                     onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.1)'; this.style.transform='translateY(-2px)'"
                     onmouseout="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.06)'; this.style.transform='translateY(0)'">
              <div style="display: flex; align-items: center; gap: 10px; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 12px;">
                {isFT && (
                  <span style="background: #0f3460; color: #fff; padding: 2px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">FT精选</span>
                )}
                {!isFT && (
                  <span style="background: var(--brand); color: #fff; padding: 2px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">写作课</span>
                )}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>{pubDate}</span>
              </div>
              <h2 style="font-family: var(--font-heading); font-size: 1.25rem; margin: 0 0 8px; line-height: 1.4;">
                <a href={`${base}/blog/${slug}`} style="color: var(--text-heading); text-decoration: none; transition: color 0.2s;"
                   onmouseover="this.style.color='var(--brand)'" onmouseout="this.style.color='var(--text-heading)'">
                  {post.data.title}
                </a>
              </h2>
              {post.data.description && (
                <p style="color: var(--text-muted); line-height: 1.6; margin: 0 0 16px; font-size: 0.9rem;">
                  {post.data.description}
                </p>
              )}
              <a href={`${base}/blog/${slug}`} style="display: inline-flex; align-items: center; gap: 6px; color: var(--brand); font-weight: 500; text-decoration: none; font-size: 0.9rem;">
                阅读全文
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </article>
          );
        })}
      </div>

      <!-- No results -->
      <div id="ft-no-results" style="display: none; text-align: center; padding: 60px 0 40px;">
        <p style="font-size: 1.1rem; color: var(--text-muted); margin: 0;">😕 未找到匹配文章</p>
      </div>

    </div>
  </div>

  <script>
    const searchInput = document.getElementById('ft-search');
    const postsContainer = document.getElementById('ft-posts');
    const noResults = document.getElementById('ft-no-results');
    const countNum = document.getElementById('ft-count-num');
    const cards = Array.from(document.querySelectorAll('.ft-card'));

    function debounce(fn, ms) {
      let timer;
      return function (...args) {
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, args), ms);
      };
    }

    function handleSearch(query) {
      const q = query.trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const title = (card.getAttribute('data-title') || '').toLowerCase();
        const matches = q === '' || title.includes(q);
        card.style.display = matches ? '' : 'none';
        if (matches) visible++;
      });

      countNum.textContent = visible;
      postsContainer.style.display = visible === 0 ? 'none' : '';
      noResults.style.display = visible === 0 ? '' : 'none';
    }

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        handleSearch('');
        searchInput.blur();
      }
    });

    searchInput.addEventListener('input', debounce(function () {
      handleSearch(this.value);
    }, 200));

    handleSearch('');
  </script>
</MainLayout>
