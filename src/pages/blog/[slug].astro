---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const postContent = post.rendered?.html ?? post.body;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = Astro.url.origin;

// Reading time
const wordCount = (post.body || '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200)) + " 分钟";

// Dates
const pubDate = new Date(post.data.pubDate);
const pubDateISO = pubDate.toISOString();
const pubDateDisplay = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// Slug for URL
const postSlug = post.id.replace(/\.(md|mdx)$/, '');
const postUrl = `${siteUrl}${base}/blog/${postSlug}`;

// ── Topic keywords extraction ──
function extractKeywords(title, slug) {
  const keywords = [];
  if (title.includes('中考') || slug.includes('zhongkao')) keywords.push('中考');
  if (title.includes('高考') || slug.includes('gaokao') || title.includes('高中') || slug.includes('high-school')) keywords.push('高考');
  if (title.includes('雅思') || slug.includes('ielts') || title.includes('雅思')) keywords.push('雅思');
  if (title.includes('读后续写') || slug.includes('continuation')) keywords.push('读后续写');
  if (title.includes('初中') || title.includes('小学') || slug.includes('junior') || slug.includes('primary') || slug.includes('ket')) keywords.push('初中');
  if (title.includes('KET') || title.includes('PET')) keywords.push('KET/PET');
  if (slug.startsWith('ft-')) keywords.push('外刊阅读');
  if (title.includes('批改') || title.includes('correction') || title.includes('批改')) keywords.push('作文批改');
  if (title.includes('句型') || title.includes('语法') || title.includes('词汇') || title.includes('词') || title.includes('句式') || title.includes('sentence') || title.includes('vocabulary')) keywords.push('词汇语法');
  if (title.includes('阅读') || slug.includes('reading')) keywords.push('阅读');
  if (title.includes('听力') || slug.includes('listening')) keywords.push('听力');
  if (keywords.length === 0) keywords.push('通用');
  return keywords;
}

// Determine primary section
const postKeywords = extractKeywords(post.data.title, post.id);
const sectionMap = {
  '中考': '中考英语', '高考': '高考英语', '雅思': '雅思写作',
  '读后续写': '高中英语写作', '初中': '初中英语', 'KET/PET': 'KET/PET',
  '外刊阅读': '外刊阅读学写作', '作文批改': '英语作文批改',
  '词汇语法': '词汇语法', '阅读': '英语阅读', '听力': '英语听力',
};
const primarySection = sectionMap[postKeywords[0]] || '英语作文批改';

// Related posts by keyword overlap (topic-based, not random)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const theirKeywords = extractKeywords(p.data.title, p.id);
    const overlap = postKeywords.filter(k => theirKeywords.includes(k)).length;
    return { post: p, score: overlap };
  })
  .sort((a, b) => b.score - a.score || Math.random() - 0.5)
  .slice(0, 5)
  .map(item => item.post);

// Pre-compute JSON-LD to avoid Astro script-type issues
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": post.data.title,
      "description": post.data.description,
      "author": {
        "@type": "Person",
        "name": post.data.author || "William",
      },
      "datePublished": pubDateISO,
      "dateModified": pubDateISO,
      "url": postUrl,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": postUrl,
      },
      "publisher": {
        "@type": "Organization",
        "name": "厦门灯塔",
        "url": siteUrl,
      },
      "inLanguage": "zh-CN",
      "wordCount": wordCount,
      "timeRequired": readingTime,
      "articleSection": primarySection,
      "keywords": postKeywords.join(', '),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "博客",
          "item": `${siteUrl}${base}/blog`,
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": post.data.title,
          "item": postUrl,
        },
      ],
    },
  ],
});
---

<MainLayout
  title={`${post.data.title} - 厦门灯塔博客`}
  description={post.data.description}
  type="article"
  publishedTime={pubDateISO}
  slug={`blog/${postSlug}`}
  canonicalUrl={postUrl}>
  <Navbar />

  <article style="padding: 80px 0 100px;">
    <div class="container" style="max-width: 720px; margin: 0 auto; padding: 0 24px;">

      <!-- Breadcrumb -->
      <nav style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 32px;">
        <a href={`${base}/blog`} style="color: var(--brand); text-decoration: none;">博客</a>
        <span style="margin: 0 8px;">/</span>
        <span>{post.data.title}</span>
      </nav>

      <!-- Title -->
      <h1 style="font-family: var(--font-heading); font-size: 2.2rem; color: var(--text-heading); line-height: 1.35; margin: 0 0 16px;">
        {post.data.title}
      </h1>

      <!-- Meta bar -->
      <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap; font-size: 0.9rem; color: var(--text-muted); padding-bottom: 28px; border-bottom: 2px solid var(--brand-light); margin-bottom: 40px;">
        {post.data.author && (
          <span style="display: flex; align-items: center; gap: 6px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {post.data.author}
          </span>
        )}
        <span style="display: flex; align-items: center; gap: 6px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {pubDateDisplay}
        </span>
        <span style="display: flex; align-items: center; gap: 6px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {readingTime}
        </span>
      </div>

      <!-- Post content -->
      <div class="post-content" set:html={postContent} />

      {/* JSON-LD Structured Data */}
      <script type="application/ld+json" set:html={jsonLd}></script>

      {/* Separator */}
      <div style="height: 1px; background: linear-gradient(to right, transparent, var(--brand-accent), transparent); margin: 56px 0 40px;" />

      {/* Footer navigation */}
      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
        <a href={`${base}/blog`} style="display: inline-flex; align-items: center; gap: 8px; color: var(--brand); font-weight: 500; text-decoration: none; transition: opacity 0.2s;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          返回博客列表
        </a>
        <button onclick="if (navigator.share) { navigator.share({title:'{post.data.title}', url: window.location.href}); }" 
                style="display: inline-flex; align-items: center; gap: 8px; background: var(--brand); color: white; border: none; padding: 10px 24px; border-radius: 50px; font-size: 0.9rem; cursor: pointer; transition: background 0.2s;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          分享
        </button>
      </div>



      {/* Related Posts */}
      {relatedPosts.length > 0 && (
        <div style="margin-top: 60px;">
          <h3 style="font-family: var(--font-heading); font-size: 1.3rem; color: var(--text-heading); margin-bottom: 20px;">📖 相关文章</h3>
          <div style="display: grid; gap: 16px;">
            {relatedPosts.map((rp) => {
              const rpSlug = rp.id.replace(/\.(md|mdx)$/, '');
              const rpDate = new Date(rp.data.pubDate).toLocaleDateString('zh-CN', {
                year: 'numeric', month: 'long', day: 'numeric',
              });
              return (
                <a href={`${base}/blog/${rpSlug}`} style="display: block; background: var(--bg-card); border-radius: var(--radius); padding: 20px 24px; box-shadow: var(--shadow-card); text-decoration: none; transition: box-shadow 0.2s, transform 0.2s;"
                   onmouseover="this.style.boxShadow='var(--shadow-hover)'; this.style.transform='translateY(-1px)'"
                   onmouseout="this.style.boxShadow='var(--shadow-card)'; this.style.transform='translateY(0)'">
                  <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 6px;">{rpDate}</div>
                  <h4 style="font-family: var(--font-heading); font-size: 1rem; color: var(--text-heading); margin: 0 0 4px; line-height: 1.4;">{rp.data.title}</h4>
                  {rp.data.description && (
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0; line-height: 1.5;">{rp.data.description}</p>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      )}

    </div>
  </article>
</MainLayout>
