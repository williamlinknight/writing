---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const postContent = post.rendered?.html ?? post.body;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<MainLayout
  title={`${post.data.title} - 厦门灯塔`}
  description={post.data.description}
>
  <Navbar />

  <div class="container" style="padding: 120px 0; max-width: 720px;">
    <article>
      <div style="color: #64748b; font-size: 0.95rem; margin-bottom: 8px;">
        {new Date(post.data.pubDate).toLocaleDateString('zh-CN')}
        {post.data.author && <span> · {post.data.author}</span>}
      </div>
      <h1 style="font-size: 2.2rem; color: var(--primary); margin-bottom: 40px;">
        {post.data.title}
      </h1>
      <div style="font-size: 1.1rem; line-height: 1.8; color: #334155;" set:html={postContent}>
    </article>
    <div style="margin-top: 60px; text-align: center;">
      <a href={`${base}/blog`} style="color: var(--primary); text-decoration: none;">← 返回博客列表</a>
    </div>
  </div>
</MainLayout>
