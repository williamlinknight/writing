---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<MainLayout 
  title="写作博客 - 厦门灯塔"
  description="英文作文写作技巧、高考提分干货、批改案例 | 厦门灯塔威廉老师"
>
  <Navbar />

  <div style="padding: 80px 0 120px;">
    <div class="container">

      <!-- Header -->
      <div style="text-align: center; margin-bottom: 60px;">
        <h1 style="font-family: var(--font-heading); font-size: 2.4rem; color: var(--text-heading); margin: 0 0 12px;">写作指导博客</h1>
        <p style="font-size: 1.1rem; color: var(--text-muted); margin: 0;">
          实用技巧 · 批改案例 · 提分策略
        </p>
      </div>

      {sortedPosts.length > 0 ? (
        <div style="display: grid; gap: 28px; max-width: 680px; margin: 0 auto;">
          {sortedPosts.map((post) => {
            const slug = post.id.replace(/\.(md|mdx)$/, '');
            const pubDate = new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <article style="background: var(--bg-card); border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow-card); transition: box-shadow 0.25s, transform 0.25s;"
                       onmouseover="this.style.boxShadow='var(--shadow-hover)'; this.style.transform='translateY(-2px)'"
                       onmouseout="this.style.boxShadow='var(--shadow-card)'; this.style.transform='translateY(0)'">
                <div style="display: flex; align-items: center; gap: 10px; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 14px;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span>{pubDate}</span>
                  {post.data.author && (
                    <>
                      <span>·</span>
                      <span>{post.data.author}</span>
                    </>
                  )}
                </div>
                <h2 style="font-family: var(--font-heading); font-size: 1.4rem; margin: 0 0 10px; line-height: 1.4;">
                  <a href={`${base}/blog/${slug}`} style="color: var(--text-heading); text-decoration: none; transition: color 0.2s;"
                     onmouseover="this.style.color='var(--brand)'" onmouseout="this.style.color='var(--text-heading)'">
                    {post.data.title}
                  </a>
                </h2>
                <p style="color: var(--text-muted); line-height: 1.7; margin: 0 0 18px; font-size: 0.95rem;">
                  {post.data.description}
                </p>
                <a href={`${base}/blog/${slug}`} style="display: inline-flex; align-items: center; gap: 6px; color: var(--brand); font-weight: 500; text-decoration: none; font-size: 0.95rem;">
                  阅读全文
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </article>
            );
          })}
        </div>
      ) : (
        <p style="text-align: center; font-size: 1.15rem; color: var(--text-muted); margin-top: 80px;">
          暂无文章，敬请期待...
        </p>
      )}
    </div>
  </div>
</MainLayout>
