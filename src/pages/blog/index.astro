---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<MainLayout 
  title="写作博客 - 厦门灯塔"
  description="英文作文写作技巧、高考提分干货、批改案例 | 厦门灯塔威廉老师"
>
  <Navbar />

  <div style="padding: 80px 0 120px;">
    <div class="container">

      <!-- Header -->
      <div style="text-align: center; margin-bottom: 40px;">
        <h1 style="font-family: var(--font-heading); font-size: 2.4rem; color: var(--text-heading); margin: 0 0 12px;">写作指导博客</h1>
        <p style="font-size: 1.1rem; color: var(--text-muted); margin: 0;">
          实用技巧 · 批改案例 · 提分策略
        </p>
      </div>

      <!-- Search Bar -->
      <div id="search-wrapper" style="max-width: 680px; margin: 0 auto 36px; position: relative;">
        <svg id="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); pointer-events: none;">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="blog-search"
          type="text"
          placeholder="搜索文章标题或关键词..."
          style="width: 100%; padding: 14px 16px 14px 48px; border: 2px solid var(--border-light); border-radius: var(--radius); font-size: 1rem; font-family: var(--font-body); background: var(--bg-card); color: var(--text-body); outline: none; transition: border-color 0.25s, box-shadow 0.25s;"
          onfocus="this.style.borderColor='var(--brand)'; this.style.boxShadow='0 0 0 3px rgba(230,126,96,0.15)'"
          onblur="this.style.borderColor='var(--border-light)'; this.style.boxShadow='none'"
        />
      </div>

      <!-- Post Count -->
      <p id="post-count" style="text-align: center; font-size: 0.9rem; color: var(--text-muted); margin: -20px 0 28px;">
        共 <span id="count-num">{sortedPosts.length}</span> 篇文章
      </p>

      <!-- Posts Grid -->
      <div id="posts-container" style="display: grid; gap: 28px; max-width: 680px; margin: 0 auto;">
        {sortedPosts.map((post) => {
          const slug = post.id.replace(/\.(md|mdx)$/, '');
          const pubDate = new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <article class="blog-card" data-title={post.data.title} data-description={post.data.description || ''} style="background: var(--bg-card); border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow-card); transition: box-shadow 0.25s, transform 0.25s;"
                     onmouseover="this.style.boxShadow='var(--shadow-hover)'; this.style.transform='translateY(-2px)'"
                     onmouseout="this.style.boxShadow='var(--shadow-card)'; this.style.transform='translateY(0)'">
              <div style="display: flex; align-items: center; gap: 10px; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 14px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>{pubDate}</span>
                {post.data.author && (
                  <>
                    <span>·</span>
                    <span>{post.data.author}</span>
                  </>
                )}
              </div>
              <h2 style="font-family: var(--font-heading); font-size: 1.4rem; margin: 0 0 10px; line-height: 1.4;">
                <a href={`${base}/blog/${slug}`} style="color: var(--text-heading); text-decoration: none; transition: color 0.2s;"
                   onmouseover="this.style.color='var(--brand)'" onmouseout="this.style.color='var(--text-heading)'">
                  {post.data.title}
                </a>
              </h2>
              <p style="color: var(--text-muted); line-height: 1.7; margin: 0 0 18px; font-size: 0.95rem;">
                {post.data.description}
              </p>
              <a href={`${base}/blog/${slug}`} style="display: inline-flex; align-items: center; gap: 6px; color: var(--brand); font-weight: 500; text-decoration: none; font-size: 0.95rem;">
                阅读全文
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </article>
          );
        })}
      </div>

      <!-- No Results -->
      <div id="no-results" style="display: none; text-align: center; padding: 60px 0 80px;">
        <p style="font-size: 1.1rem; color: var(--text-muted); margin: 0;">
          😕 未找到匹配的文章
        </p>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin: 8px 0 0;">
          试试其他关键词搜索
        </p>
      </div>

      <!-- Pagination -->
      <div id="pagination" style="display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 48px; flex-wrap: wrap; display: none;">
      </div>

    </div>
  </div>

  <script>
    const POSTS_PER_PAGE = 12;
    let currentPage = 1;
    let lastQuery = '';

    const searchInput = document.getElementById('blog-search');
    const postsContainer = document.getElementById('posts-container');
    const noResults = document.getElementById('no-results');
    const countNum = document.getElementById('count-num');
    const paginationEl = document.getElementById('pagination');
    const cards = Array.from(postsContainer.querySelectorAll('.blog-card'));

    // Debounce helper
    function debounce(fn, ms) {
      let timer;
      return function (...args) {
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, args), ms);
      };
    }

    function renderPagination(totalVisible) {
      const totalPages = Math.ceil(totalVisible / POSTS_PER_PAGE);
      if (totalPages <= 1) {
        paginationEl.style.display = 'none';
        return;
      }
      paginationEl.style.display = 'flex';
      paginationEl.innerHTML = '';

      // Prev button
      const prevBtn = document.createElement('button');
      prevBtn.textContent = '‹';
      prevBtn.style.cssText = 'padding: 8px 14px; border: 1px solid var(--border-light); background: var(--bg-card); color: var(--text-body); border-radius: var(--radius); cursor: pointer; font-size: 1rem; transition: background 0.2s;';
      prevBtn.disabled = currentPage === 1;
      if (prevBtn.disabled) prevBtn.style.opacity = '0.4';
      prevBtn.addEventListener('click', () => { if (currentPage > 1) { currentPage--; applyPagination(); } });
      paginationEl.appendChild(prevBtn);

      // Page numbers
      const maxVisiblePages = 7;
      let startPage = Math.max(1, currentPage - 3);
      let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
      if (endPage - startPage < maxVisiblePages - 1) {
        startPage = Math.max(1, endPage - maxVisiblePages + 1);
      }

      for (let i = startPage; i <= endPage; i++) {
        const pageBtn = document.createElement('button');
        pageBtn.textContent = i;
        const isActive = i === currentPage;
        pageBtn.style.cssText = `padding: 8px 14px; border: 1px solid ${isActive ? 'var(--brand)' : 'var(--border-light)'}; background: ${isActive ? 'var(--brand)' : 'var(--bg-card)'}; color: ${isActive ? '#fff' : 'var(--text-body)'}; border-radius: var(--radius); cursor: pointer; font-size: 0.95rem; font-weight: ${isActive ? '600' : '400'}; transition: all 0.2s;`;
        pageBtn.addEventListener('click', () => { currentPage = i; applyPagination(); });
        paginationEl.appendChild(pageBtn);
      }

      // Next button
      const nextBtn = document.createElement('button');
      nextBtn.textContent = '›';
      nextBtn.style.cssText = 'padding: 8px 14px; border: 1px solid var(--border-light); background: var(--bg-card); color: var(--text-body); border-radius: var(--radius); cursor: pointer; font-size: 1rem; transition: background 0.2s;';
      nextBtn.disabled = currentPage === totalPages;
      if (nextBtn.disabled) nextBtn.style.opacity = '0.4';
      nextBtn.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; applyPagination(); } });
      paginationEl.appendChild(nextBtn);
    }

    function filterPosts(query) {
      const q = query.trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const title = (card.getAttribute('data-title') || '').toLowerCase();
        const desc = (card.getAttribute('data-description') || '').toLowerCase();
        const matches = q === '' || title.includes(q) || desc.includes(q);
        card.dataset.visible = matches ? '1' : '0';
        if (matches) visibleCount++;
      });

      return visibleCount;
    }

    function applyPagination() {
      const visibleCards = cards.filter(c => c.dataset.visible === '1');
      const totalVisible = visibleCards.length;

      // Update post count display
      countNum.textContent = totalVisible;

      if (totalVisible === 0) {
        postsContainer.style.display = 'none';
        noResults.style.display = '';
        paginationEl.style.display = 'none';
        return;
      }

      postsContainer.style.display = '';
      noResults.style.display = 'none';

      // If showing search results, show all (no pagination)
      if (lastQuery.trim() !== '') {
        cards.forEach((card) => {
          card.style.display = card.dataset.visible === '1' ? '' : 'none';
        });
        paginationEl.style.display = 'none';
        return;
      }

      // Paginate
      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;

      cards.forEach((card, i) => {
        if (card.dataset.visible === '1' && i >= start && i < end) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });

      renderPagination(totalVisible);
    }

    function handleSearch(query) {
      lastQuery = query;
      currentPage = 1;
      const visibleCount = filterPosts(query);
      applyPagination();
    }

    // Clear search button (Escape key)
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        handleSearch('');
        searchInput.blur();
      }
    });

    searchInput.addEventListener('input', debounce(function () {
      handleSearch(this.value);
    }, 200));

    // Initial render
    handleSearch('');
  </script>
</MainLayout>
