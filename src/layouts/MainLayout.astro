---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  slug?: string;
}

const {
  title,
  description = "厦门灯塔 | 英文作文逐句批改服务",
  image,
  type = "website",
  publishedTime,
  slug,
} = Astro.props;

const siteUrl = "https://www.williamwriting.com";
const pageUrl = slug ? `${siteUrl}/${slug}` : Astro.url.href;
const ogImage = image || `${siteUrl}/og-default.png`;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="厦门灯塔博客" />
  <meta property="og:locale" content="zh_CN" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="厦门灯塔 | 英文作文批改博客" href="/rss.xml" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )}

  {/* Fonts */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Favicon & App Icons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#E67E60" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="厦门灯塔" />

  <style>
    /* ── Brand tokens ── */
    :root {
      --brand: #E67E60;
      --brand-light: #FFF8EF;
      --brand-dark: #D87C52;
      --brand-accent: #E8D3B5;
      --text-heading: #222222;
      --text-body: #3a3a3a;
      --text-muted: #666666;
      --bg-page: #FFFAF5;
      --bg-card: #FFFFFF;
      --border-light: #F0E8E0;
      --radius: 12px;
      --shadow-card: 0 2px 12px rgba(230, 126, 96, 0.08);
      --shadow-hover: 0 4px 24px rgba(230, 126, 96, 0.14);
      --font-heading: 'Noto Serif SC', 'Source Han Serif SC', serif;
      --font-body: 'Inter', 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif;
    }

    * { box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      margin: 0;
      line-height: 1.8;
      color: var(--text-body);
      background: var(--bg-page);
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ── Markdown content styling (used in blog posts) ── */
    .post-content {
      font-size: 1.05rem;
      line-height: 1.9;
      color: var(--text-body);
    }
    .post-content h2 {
      font-family: var(--font-heading);
      font-size: 1.55rem;
      color: var(--text-heading);
      margin: 2em 0 0.8em;
      padding-bottom: 0.4em;
      border-bottom: 2px solid var(--brand-light);
    }
    .post-content h3 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      color: var(--text-heading);
      margin: 1.8em 0 0.6em;
    }
    .post-content p {
      margin: 0 0 1.2em;
    }
    .post-content a {
      color: var(--brand);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--brand-accent);
      transition: text-decoration-color 0.2s;
    }
    .post-content a:hover {
      text-decoration-color: var(--brand);
    }
    .post-content strong {
      color: var(--text-heading);
      font-weight: 600;
    }
    .post-content blockquote {
      margin: 1.5em 0;
      padding: 16px 24px;
      border-left: 4px solid var(--brand);
      background: var(--brand-light);
      border-radius: 0 var(--radius) var(--radius) 0;
      font-style: italic;
      color: var(--text-muted);
    }
    .post-content ul, .post-content ol {
      padding-left: 1.5em;
      margin: 0 0 1.2em;
    }
    .post-content li {
      margin-bottom: 0.4em;
    }
    .post-content code {
      background: #f5f0eb;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.9em;
      color: var(--brand-dark);
    }
    .post-content pre {
      background: #2d2d2d;
      color: #f0e8e0;
      padding: 20px 24px;
      border-radius: var(--radius);
      overflow-x: auto;
      font-size: 0.9em;
      line-height: 1.6;
    }
    .post-content pre code {
      background: none;
      padding: 0;
      color: inherit;
    }
    .post-content img {
      max-width: 100%;
      height: auto;
      border-radius: var(--radius);
      margin: 1.5em 0;
      box-shadow: var(--shadow-card);
    }
    .post-content hr {
      border: none;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--brand-accent), transparent);
      margin: 2.5em 0;
    }
    .post-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5em 0;
      font-size: 0.95em;
    }
    .post-content th {
      background: var(--brand-light);
      color: var(--text-heading);
      font-weight: 600;
      padding: 10px 14px;
      text-align: left;
    }
    .post-content td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border-light);
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
